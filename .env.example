# AWS Bedrock (all AI models accessed through Bedrock)
# Required: Orchestrator (Nova Pro), Vision (Claude Haiku 4.5), Browser (Claude Haiku 4.5)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_SESSION_TOKEN=your-aws-session-token-if-using-temporary-credentials
AWS_REGION=us-east-1

# Orchestrator Framework Selection
# Set to "true" to use Strands Agents SDK, "false" (default) for direct Bedrock Converse API
USE_STRANDS=false

# Legacy: Anthropic API (no longer needed - all models via Bedrock)
# ANTHROPIC_API_KEY=sk-ant-...

# Local Storage
LOCAL_STORAGE_PATH=/local-storage
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=your-fernet-key-here

# Services (Docker internal names)
BROWSER_SANDBOX_CDP=http://browser-sandbox:9222
NOVNC_URL=http://browser-sandbox:6080
SANDBOX_RECORDER_URL=http://browser-sandbox:8888

# Backend
DATABASE_URL=sqlite:///./data/aethertest.db
FRONTEND_URL=http://localhost:3000

# Memory Layer Configuration
# "local" = SQLite (development), "agentcore" = AWS Bedrock AgentCore Memory (production)
MEMORY_STORE_TYPE=local
MEMORY_DB_PATH=./data/memory.db
# AWS AgentCore Memory (for production deployment)
# AGENTCORE_MEMORY_ID=your-memory-id
# AGENTCORE_MEMORY_REGION=us-west-2

# Optional
LOG_LEVEL=INFO
MAX_TURNS=100
